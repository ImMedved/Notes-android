<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:angle="0"
                android:endColor="#E9DDFE"
                android:startColor="#FFF6ED" />
        </shape>
    </item>
    <item
        android:bottom="24dp"
        android:left="22dp"
        android:right="22dp"
        android:top="24dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="#FFFFFCF7" />
            <stroke
                android:width="2dp"
                android:color="#C9A86A" />
        </shape>
    </item>
</layer-list>
